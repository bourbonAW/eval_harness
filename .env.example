# Stage 4 (LLM judges) - not used in Stage 2 but listed for forward planning
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1  # override for compatible endpoints

# Workflow platform (Stage 2 - required)
WORKFLOW_API_BASE_URL=https://your-host
WORKFLOW_API_KEY=Bearer eyJ...
WORKFLOW_SESSION_ID=your-session-id
WORKFLOW_CHANNEL_ID=1
WORKFLOW_CONNECT_TIMEOUT=10
WORKFLOW_READ_TIMEOUT=300

# Response field names - update to match your workflow's actual output fields
WORKFLOW_ANSWER_FIELD=answer
WORKFLOW_COMPLETE_QUESTION_FIELD=complete_question
WORKFLOW_DOC_STR_FIELD=doc_str
WORKFLOW_FAQ_STR_FIELD=faq_str
WORKFLOW_REF_STR_FIELD=ref_str
WORKFLOW_REF_NUM_FIELD=ref_num
